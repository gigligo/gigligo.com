# Database URL format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://root:password@localhost:5432/freelapk?schema=public"

# Auth setup
JWT_SECRET="super-secret-jwt-key"
JWT_REFRESH_SECRET="super-secret-refresh-key"

# Payment gateways
JAZZ_KEY="sandbox-jazz-key"
JAZZ_SECRET="sandbox-jazz-secret"
EASY_KEY="sandbox-easypaisa-key"
EASY_SECRET="sandbox-easypaisa-secret"

# Third-party integrations
TWILIO_SID="mock-twilio-sid"
TWILIO_TOKEN="mock-twilio-token"
SENDGRID_API_KEY="mock-sendgrid-api-key"
CLOUDINARY_URL="mock-cloudinary-url"
OCR_KEY="mock-ocr-key"
SENTRY_DSN="mock-sentry-dsn"

# AWS S3 Cloud Storage (leave empty to use local disk)
AWS_S3_BUCKET=""
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
