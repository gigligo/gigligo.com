generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════
// USER & PROFILE
// ═══════════════════════════════════════

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  googleId         String?   @unique
  phone            String?   @unique
  role             Role      @default(FREE)
  credits          Int       @default(0)
  isFoundingMember Boolean   @default(false)
  nationalId       String?   @unique
  kycStatus        KYCStatus @default(UNVERIFIED)
  paymentVerified  Boolean   @default(false)
  isSuspended      Boolean   @default(false)
  termsAcceptedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  profile       Profile?
  kyc           KYC?
  subscriptions Subscription?
  gigs          Gig[]
  ordersPlaced  Order[]          @relation("BuyerOrders")
  ordersTaken   Order[]          @relation("SellerOrders")
  reviewsGiven  Review[]         @relation("Reviewer")
  reviewsRecvd  Review[]         @relation("Reviewee")
  wallet        Wallet?
  jobsPosted    Job[]
  applications  JobApplication[]
  creditLedger  CreditLedger[]
  transactions  Transaction[]
  notifications Notification[]

  conversationsAsFreelancer Conversation[] @relation("ConversationFreelancer")
  conversationsAsEmployer   Conversation[] @relation("ConversationEmployer")
  sentMessages              Message[]      @relation("MessageSender")

  disputesInitiated Dispute[] @relation("DisputeInitiator")
  disputesDefended  Dispute[] @relation("DisputeDefendant")

  // Contracts
  contractsAsFreelancer Contract[] @relation("FreelancerContracts")
  contractsAsEmployer   Contract[] @relation("EmployerContracts")

  // Audit Logs
  auditLogs AuditLog[] @relation("UserAuditLogs")

  // 2FA & Verification Fields
  twoFactorSecret    String?
  isTwoFactorEnabled Boolean @default(false)
  emailVerified      Boolean @default(false)

  // Referral System
  referralCode       String?   @unique
  referredBy         User?     @relation("UserReferral", fields: [referredById], references: [id])
  referredById       String?
  referredUsers      User[]    @relation("UserReferral")
  referralsGiven     Referral[] @relation("ReferralGiver")
  referralsReceived  Referral[] @relation("ReferralReceiver")

  // Authentication
  refreshTokens      RefreshToken[]
}

model Profile {
  id                 String      @id @default(cuid())
  user               User        @relation(fields: [userId], references: [id])
  userId             String      @unique
  fullName           String
  avatarUrl          String?
  bio                String?
  location           String?
  languages          String[]
  verifiedStudent    Boolean     @default(false)
  skills             String[]
  portfolio          String[]
  hourlyRate         Int?
  foundingMemberType String?
  sellerLevel        SellerLevel @default(NEW)

  // New LinkedIn-style fields
  websiteUrl     String?
  linkedinUrl    String?
  githubUrl      String?
  experiences    Experience[]
  educations     Education[]
  portfolioItems PortfolioItem[]
}

// ═══════════════════════════════════════
// AUTHENTICATION
// ═══════════════════════════════════════

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  expiresAt   DateTime
  isRevoked   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════
// PORTFOLIO, EXPERIENCE, EDUCATION
// ═══════════════════════════════════════

model Experience {
  id          String    @id @default(cuid())
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId   String
  title       String
  company     String
  startDate   DateTime
  endDate     DateTime?
  description String?
  isCurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Education {
  id          String   @id @default(cuid())
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId   String
  degree      String
  institution String
  startYear   Int
  endYear     Int?
  description String?
  createdAt   DateTime @default(now())
}

model PortfolioItem {
  id          String   @id @default(cuid())
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId   String
  title       String
  description String?
  imageUrl    String?
  linkUrl     String?
  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════
// KYC
// ═══════════════════════════════════════

model KYC {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String    @unique
  cnicFrontUrl String
  cnicBackUrl  String
  selfieUrl    String
  status       KYCStatus @default(PENDING)
  submittedAt  DateTime  @default(now())
  reviewedAt   DateTime?
  reviewerId   String?
}

// ═══════════════════════════════════════
// GIG (existing Fiverr-style flow)
// ═══════════════════════════════════════

model Gig {
  id                   String   @id @default(cuid())
  seller               User     @relation(fields: [sellerId], references: [id])
  sellerId             String
  title                String
  description          String
  category             String
  tags                 String[]
  priceStarter         Int
  priceStandard        Int
  pricePremium         Int
  deliveryTimeStarter  Int
  deliveryTimeStandard Int
  deliveryTimePremium  Int
  portfolioUrls        String[]
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?
  orders               Order[]
  reviews              Review[]
  boosts               Boost[]
  avgRating            Float            @default(0)
  reviewCount          Int              @default(0)

  @@index([sellerId])
  @@index([category])
  @@index([isActive, createdAt])
}

// ═══════════════════════════════════════
// JOB (new job-board flow)
// ═══════════════════════════════════════

model Job {
  id           String           @id @default(cuid())
  employer     User             @relation(fields: [employerId], references: [id])
  employerId   String
  title        String
  description  String
  category     String
  tags         String[]
  budgetMin    Int
  budgetMax    Int
  deadline     DateTime?
  location     String?
  jobType      JobType          @default(REMOTE)
  status       JobStatus        @default(OPEN)
  isBoosted    Boolean          @default(false)
  boostExpiry  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  applications JobApplication[]
  contracts    Contract[]
  Conversation Conversation[]
  disputes     Dispute[]

  @@index([employerId])
  @@index([category])
  @@index([status, createdAt])
}

model JobApplication {
  id           String            @id @default(cuid())
  job          Job               @relation(fields: [jobId], references: [id])
  jobId        String
  freelancer   User              @relation(fields: [freelancerId], references: [id])
  freelancerId String
  coverLetter  String
  proposedRate Int?
  timeline     String?
  status       ApplicationStatus @default(PENDING)
  appliedAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  contract     Contract?

  @@unique([jobId, freelancerId])
  @@index([freelancerId])
  @@index([status])
}

// ═══════════════════════════════════════
// CONTRACTS (Business ↔ Freelancer Agreements)
// ═══════════════════════════════════════

model Contract {
  id              String         @id @default(cuid())
  job             Job            @relation(fields: [jobId], references: [id])
  jobId           String
  application     JobApplication @relation(fields: [applicationId], references: [id])
  applicationId   String         @unique
  freelancer      User           @relation("FreelancerContracts", fields: [freelancerId], references: [id])
  freelancerId    String
  employer        User           @relation("EmployerContracts", fields: [employerId], references: [id])
  employerId      String
  amount          Int
  status          ContractStatus @default(ACTIVE)
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([freelancerId])
  @@index([employerId])
  @@index([status])
}



// ═══════════════════════════════════════
// ORDERS & REVIEWS
// ═══════════════════════════════════════

model Order {
  id              String         @id @default(cuid())
  buyer           User           @relation("BuyerOrders", fields: [buyerId], references: [id])
  buyerId         String
  seller          User           @relation("SellerOrders", fields: [sellerId], references: [id])
  sellerId        String
  gig             Gig            @relation(fields: [gigId], references: [id])
  gigId           String
  packageSelected Package
  price           Int
  escrowAmount    Int
  commission      Int            @default(0)
  status          OrderStatus    @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deadline        DateTime
  deliveryUrl     String?
  buyerRating     Int?
  buyerReview     String?
  escrowReleased  Boolean        @default(false)
  paymentIntentId String?
  platformRevenue PlatformRevenue?
  Conversation    Conversation[]
  disputes        Dispute[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status, createdAt])
}

model Review {
  id         String   @id @default(cuid())
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewerId String
  reviewee   User     @relation("Reviewee", fields: [revieweeId], references: [id])
  revieweeId String
  gig        Gig?     @relation(fields: [gigId], references: [id])
  gigId      String?
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
}

// ═══════════════════════════════════════
// WALLET & CREDITS
// ═══════════════════════════════════════

model Wallet {
  id         String @id @default(cuid())
  user       User   @relation(fields: [userId], references: [id])
  userId     String @unique
  balancePKR Int    @default(0)
  pendingPKR Int    @default(0)
}

model CreditPackage {
  id          String  @id @default(cuid())
  name        String
  credits     Int
  pricePKR    Int
  description String?
  isActive    Boolean @default(true)
}

model CreditLedger {
  id           String       @id @default(cuid())
  user         User         @relation(fields: [userId], references: [id])
  userId       String
  amount       Int
  type         CreditTxType
  reason       String
  balanceAfter Int
  createdAt    DateTime     @default(now())

  @@index([userId, createdAt])
}

// ═══════════════════════════════════════
// TRANSACTIONS (money movements)
// ═══════════════════════════════════════

model Transaction {
  id          String         @id @default(cuid())
  user        User           @relation(fields: [userId], references: [id])
  userId      String
  amountPKR   Int
  type        TxType
  status      TxStatus       @default(PENDING)
  method      PaymentMethod?
  reference   String?
  description String?
  createdAt   DateTime       @default(now())

  @@index([userId, createdAt])
}

// ═══════════════════════════════════════
// PLATFORM REVENUE
// ═══════════════════════════════════════

model PlatformRevenue {
  id          String   @id @default(cuid())
  orderId     String?  @unique
  order       Order?   @relation(fields: [orderId], references: [id])
  amountPKR   Int
  reason      String
  createdAt   DateTime @default(now())
}

// ═══════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

// ═══════════════════════════════════════
// SUBSCRIPTION & BOOST (existing)
// ═══════════════════════════════════════

model Subscription {
  id                  String           @id @default(cuid())
  user                User             @relation(fields: [userId], references: [id])
  userId              String           @unique
  tier                SubscriptionTier
  startDate           DateTime         @default(now())
  endDate             DateTime?
  lastBonusCreditDate DateTime?
}

model Boost {
  id          String   @id @default(cuid())
  gig         Gig      @relation(fields: [gigId], references: [id])
  gigId       String
  purchasedAt DateTime @default(now())
  expiresAt   DateTime
  amountPKR   Int

  @@index([gigId])
  @@index([expiresAt])
}

// ═══════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════

enum Role {
  FREE
  BUYER
  SELLER
  STUDENT
  EMPLOYER
  ADMIN
  SUPPORT
}

enum KYCStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum Package {
  STARTER
  STANDARD
  PREMIUM
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
}

enum JobType {
  REMOTE
  ONSITE
  HYBRID
}

enum JobStatus {
  OPEN
  CLOSED
  FILLED
  EXPIRED
  ARCHIVED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  HIRED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum CreditTxType {
  PURCHASE
  DEDUCTION
  REFUND
  BONUS
}

enum TxType {
  CREDIT_PURCHASE
  COMMISSION
  WITHDRAWAL
  EARNING
  REFUND
  BOOST
  SUBSCRIPTION
  PAYMENT
  CREDIT_BONUS
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  JAZZCASH
  EASYPAISA
  BANK_TRANSFER
  PAYPAL
}

enum NotificationType {
  APPLICATION_SUBMITTED
  APPLICATION_HIRED
  APPLICATION_REJECTED
  APPLICATION_SHORTLISTED
  NEW_MESSAGE
  LOW_CREDITS
  PAYMENT_RECEIVED
  ORDER_UPDATE
  SUBSCRIPTION_ACTIVATED
  KYC_APPROVED
  KYC_REJECTED
  SYSTEM
}

enum SubscriptionTier {
  FREE
  STANDARD
  PREMIUM
  PRO
}

enum DisputeStatus {
  OPEN
  RESOLVED_BUYER
  RESOLVED_SELLER
}

enum SellerLevel {
  NEW
  LEVEL_1
  LEVEL_2
  TOP_RATED
}

model Conversation {
  id String @id @default(cuid())

  // Participants
  freelancerId String
  employerId   String
  freelancer   User   @relation("ConversationFreelancer", fields: [freelancerId], references: [id])
  employer     User   @relation("ConversationEmployer", fields: [employerId], references: [id])

  // Contexts
  orderId String?
  jobId   String?
  order   Order?  @relation(fields: [orderId], references: [id])
  job     Job?    @relation(fields: [jobId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([freelancerId, employerId, orderId])
}

model Message {
  id         String  @id @default(cuid())
  content    String
  isRead     Boolean @default(false)
  attachment String?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id])

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

// ═══════════════════════════════════════
// DISPUTES
// ═══════════════════════════════════════

model Dispute {
  id          String        @id @default(cuid())
  order       Order?        @relation(fields: [orderId], references: [id])
  orderId     String?
  job         Job?          @relation(fields: [jobId], references: [id])
  jobId       String?
  initiator   User          @relation("DisputeInitiator", fields: [initiatorId], references: [id])
  initiatorId String
  defendant   User          @relation("DisputeDefendant", fields: [defendantId], references: [id])
  defendantId String
  reason      String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?
}

// ═══════════════════════════════════════
// REFERRAL SYSTEM
// ═══════════════════════════════════════

model Referral {
  id          String   @id @default(cuid())
  referrer    User     @relation("ReferralGiver", fields: [referrerId], references: [id])
  referrerId  String
  referee     User     @relation("ReferralReceiver", fields: [refereeId], references: [id])
  refereeId   String
  bonusGiven  Int      @default(10)
  createdAt   DateTime @default(now())

  @@unique([referrerId, refereeId])
  @@index([referrerId])
}

// ═══════════════════════════════════════
// NEWSLETTER
// ═══════════════════════════════════════

model NewsletterSubscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  subscribedAt  DateTime @default(now())
  isActive      Boolean  @default(true)
}

// ═══════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserAuditLogs", fields: [userId], references: [id])
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ═══════════════════════════════════════
// OTP CODES (Email-based login verification)
// ═══════════════════════════════════════

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      OtpType
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, type, used])
}

enum OtpType {
  LOGIN
  EMAIL_VERIFY
  PHONE_VERIFY
}
